{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/course-platform run build",
  "outputDirectory": "artifacts/course-platform/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "env": {
    "BASE_PATH": "/"
  },
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
